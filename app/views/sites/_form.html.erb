<%= form_with model: site, url: url, method: defined?(method) ? method : :post do |f| %>
  <% if site.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
      <% site.errors.full_messages.each do |msg| %>
        <p class="text-red-700 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <label class="form-label">発電所名 <span class="text-red-500">*</span></label>
      <%= f.text_field :name, class: "form-input", placeholder: "例：南部第1発電所" %>
    </div>
    <div>
      <label class="form-label">所在地 <span class="text-red-500">*</span></label>
      <%= f.text_field :location, class: "form-input", placeholder: "例：山梨県甲府市" %>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="form-label">パネル枚数</label>
        <%= f.number_field :panel_count, class: "form-input", min: 1, max: 200, value: site.panel_count || 20 %>
        <p class="text-xs text-gray-400 mt-1">登録時にパネルを自動生成します</p>
      </div>
      <div>
        <label class="form-label">設備容量（kW）</label>
        <%= f.number_field :capacity_kw, class: "form-input", step: 0.1, min: 0 %>
      </div>
    </div>
    <div>
      <label class="form-label">ステータス</label>
      <%= f.select :status,
          options_for_select([["稼働中", "active"], ["停止", "inactive"], ["点検中", "maintenance"]], site.status),
          {}, class: "form-select" %>
    </div>
    <div>
      <label class="form-label">説明（任意）</label>
      <%= f.text_area :description, class: "form-textarea", rows: 3, placeholder: "発電所の特記事項など" %>
    </div>
    <div class="flex justify-end gap-3 pt-2">
      <%= link_to "キャンセル", sites_path, class: "btn btn-secondary" %>
      <%= f.submit site.new_record? ? "登録する" : "更新する", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>