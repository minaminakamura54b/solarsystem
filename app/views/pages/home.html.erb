<footer>
  <p>© 2026 SolarSight AI — 太陽光発電 AI管理システム</p>
</footer>

<script>
const grid = document.getElementById('panelDemoGrid');
const states = Array.from({length: 96}, (_, i) => {
  if ([7, 12, 31, 44].includes(i)) return 'err';
  if ([2, 18, 55, 67].includes(i)) return 'warn';
  if (i > 90) return 'off';
  return 'ok';
});

states.forEach(s => {
  const cell = document.createElement('div');
  cell.className = `pc ${s}`;
  grid.appendChild(cell);
});

setInterval(() => {
  const cells = grid.querySelectorAll('.pc.err');
  cells.forEach(c => {
    c.style.opacity = c.style.opacity === '0.4' ? '1' : '0.4';
  });
}, 1000);
</script>
</body>
</html>
