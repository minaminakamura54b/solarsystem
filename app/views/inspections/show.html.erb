<% content_for :title, "点検詳細 - #{@inspection.conducted_at.strftime('%Y/%m/%d')}" %>

<div class="page-header">
  <div>
    <h2 class="page-title">🔍 点検詳細</h2>
    <p class="text-sm text-gray-500 mt-1"><%= current_site&.name %> - <%= @inspection.conducted_at.strftime("%Y年%m月%d日 %H:%M") %></p>
  </div>
  <%= link_to "← 一覧に戻る", inspections_path, class: "btn btn-secondary" %>
</div>

<div class="p-6">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <%# 左カラム：画像 + 解析状況 %>
    <div class="space-y-4">
      <div class="card p-4">
        <h3 class="font-semibold text-gray-700 mb-3">撮影画像</h3>
        <% if @inspection.image.attached? %>
          <%= image_tag @inspection.image, class: "w-full rounded-lg object-cover" %>
        <% else %>
          <div class="bg-gray-100 rounded-lg h-48 flex items-center justify-center text-gray-400">
            画像なし
          </div>
        <% end %>
      </div>

      <div class="card p-4">
        <h3 class="font-semibold text-gray-700 mb-3">解析状況</h3>
        <div class="space-y-2" id="analysis-status"
             <% if @inspection.analyzing? %>
               data-controller="auto-refresh"
               data-auto-refresh-url-value="<%= inspection_path(@inspection, format: :json) %>"
               data-auto-refresh-interval-value="3000"
             <% end %>>
          <div class="flex items-center gap-2">
            <span class="status-dot <%= @inspection.analysis_status %>"></span>
            <span class="font-medium">
              <%= { "pending" => "待機中", "analyzing" => "AI解析中...", "completed" => "解析完了", "failed" => "解析失敗" }[@inspection.analysis_status] %>
            </span>
          </div>
          <% if @inspection.completed? %>
            <div class="flex items-center gap-2 mt-2">
              <span class="badge <%= @inspection.severity_color_class %>"><%= @inspection.severity_label %></span>
              <span class="text-sm text-gray-600">異常検出: <%= @inspection.anomaly_count %>件</span>
            </div>
          <% elsif @inspection.analyzing? %>
            <div class="flex items-center gap-2 text-blue-600 text-sm mt-2">
              <span class="animate-spin">⚙</span> Claude AIが画像を解析中です...
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# 右カラム：解析結果 %>
    <div class="space-y-4">
      <% if @inspection.completed? %>
        <%# 異常一覧 %>
        <div class="card p-4">
          <h3 class="font-semibold text-gray-700 mb-3">検出された異常</h3>
          <% if @inspection.anomalies.any? %>
            <div class="space-y-3">
              <% @inspection.anomalies.each do |anomaly| %>
                <div class="border rounded-lg p-3 <%= anomaly['severity'] == 'critical' ? 'border-red-200 bg-red-50' : 'border-yellow-200 bg-yellow-50' %>">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="badge <%= anomaly['severity'] == 'critical' ? 'badge-error' : 'badge-warning' %>">
                      <%= anomaly['severity'] == 'critical' ? '重大' : '注意' %>
                    </span>
                    <span class="font-medium text-sm"><%= anomaly['type'] %></span>
                    <span class="text-xs text-gray-500">(<%= anomaly['location'] %>)</span>
                  </div>
                  <p class="text-sm text-gray-700"><%= anomaly['description'] %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-green-600 text-sm">✓ 異常は検出されませんでした</p>
          <% end %>
        </div>

        <%# 点検レポート %>
        <div class="card p-4">
          <h3 class="font-semibold text-gray-700 mb-3">点検レポート</h3>
          <div class="text-sm text-gray-700 leading-relaxed prose max-w-none">
            <%= simple_format @inspection.report %>
          </div>
        </div>

      <% elsif @inspection.analyzing? %>
        <div class="card p-8 text-center">
          <div class="text-4xl mb-3">🤖</div>
          <p class="font-medium text-gray-700">AI解析中...</p>
          <p class="text-sm text-gray-500 mt-1">しばらくお待ちください</p>
        </div>

      <% elsif @inspection.failed? %>
        <div class="card p-6 bg-red-50 border border-red-200">
          <h3 class="font-semibold text-red-700 mb-2">解析に失敗しました</h3>
          <p class="text-sm text-red-600"><%= @inspection.result %></p>
        </div>

      <% else %>
        <div class="card p-8 text-center text-gray-400">
          <p>解析待機中...</p>
        </div>
      <% end %>
    </div>

  </div>
</div>