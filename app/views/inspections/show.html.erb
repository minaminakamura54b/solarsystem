<% content_for :title, "点検詳細 - #{@inspection.conducted_at.strftime('%Y/%m/%d')}" %>

<div class="page-header">
  <div>
    <h2 class="page-title">🔍 点検詳細</h2>
    <p class="text-sm text-gray-500 mt-1"><%= current_site&.name %> — <%= @inspection.conducted_at.strftime("%Y年%m月%d日 %H:%M") %></p>
  </div>
  <%= link_to "← 一覧に戻る", inspections_path, class: "btn btn-secondary" %>
</div>

<div class="p-6 space-y-6">

  <%# ── サマリーバー ─────────────────────────────── %>
  <% if @inspection.completed? %>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--card-border); border-radius:14px; overflow:hidden;">
      <div style="background:var(--gray-900); padding:1.5rem; text-align:center;">
        <p style="font-size:0.65rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.6rem;">重要度</p>
        <span class="badge <%= @inspection.severity_color_class %>" style="font-size:0.85rem; padding:0.35rem 1rem;">
          <%= @inspection.severity_label %>
        </span>
      </div>
      <div style="background:var(--gray-900); padding:1.5rem; text-align:center;">
        <p style="font-size:0.65rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.25rem;">検出異常</p>
        <p style="font-size:2.2rem; font-weight:700; font-family:'DM Mono',monospace; line-height:1; color:<%= @inspection.anomaly_count > 0 ? 'var(--red)' : 'var(--green)' %>;">
          <%= @inspection.anomaly_count %><span style="font-size:0.9rem; color:var(--gray-400);">件</span>
        </p>
      </div>
      <div style="background:var(--gray-900); padding:1.5rem; text-align:center;">
        <p style="font-size:0.65rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.5rem;">点検日時</p>
        <p style="font-size:0.875rem; color:var(--white); font-family:'DM Mono',monospace;">
          <%= @inspection.conducted_at.strftime("%Y/%m/%d") %><br>
          <span style="color:var(--gray-400); font-size:0.8rem;"><%= @inspection.conducted_at.strftime("%H:%M") %></span>
        </p>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <%# ── 左カラム ──────────────────────────────────── %>
    <div class="space-y-4">

      <%# 撮影画像 %>
      <div class="card p-4">
        <p style="font-size:0.65rem; font-weight:600; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.75rem;">撮影画像</p>
        <% if @inspection.image.attached? %>
          <%= image_tag @inspection.image, class: "w-full rounded-lg object-cover" %>
        <% else %>
          <div style="background:rgba(255,255,255,0.04); border-radius:0.5rem; height:12rem; display:flex; align-items:center; justify-content:center; color:var(--gray-400); font-size:0.875rem;">
            画像なし
          </div>
        <% end %>
      </div>

      <%# 解析状況 %>
      <div class="card p-4" id="analysis-status"
           <% if @inspection.analyzing? %>
             data-controller="auto-refresh"
             data-auto-refresh-url-value="<%= inspection_path(@inspection, format: :json) %>"
             data-auto-refresh-interval-value="3000"
           <% end %>>
        <p style="font-size:0.65rem; font-weight:600; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.75rem;">解析状況</p>
        <div style="display:flex; align-items:center; gap:0.75rem;">
          <span class="status-dot <%= @inspection.analysis_status %>"></span>
          <span style="font-weight:500; font-size:0.9rem;">
            <%= { "pending" => "待機中", "analyzing" => "AI解析中...", "completed" => "解析完了", "failed" => "解析失敗" }[@inspection.analysis_status] %>
          </span>
        </div>
        <% if @inspection.analyzing? %>
          <div style="margin-top:0.75rem; padding:0.75rem 1rem; background:rgba(29,158,117,0.08); border-radius:0.5rem; border:1px solid rgba(29,158,117,0.2); display:flex; align-items:center; gap:0.5rem; font-size:0.8rem; color:#5DCAA5;">
            <span class="animate-spin">⚙</span> Claude AIが画像を解析中です...
          </div>
        <% end %>
      </div>

      <%# AI概要 %>
      <% if @inspection.completed? && @display_summary.present? %>
        <div class="card p-4">
          <p style="font-size:0.65rem; font-weight:600; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.75rem;">AI概要</p>
          <p style="font-size:0.875rem; color:var(--gray-200); line-height:1.8;"><%= @display_summary %></p>
        </div>
      <% end %>

    </div>

    <%# ── 右カラム ──────────────────────────────────── %>
    <div class="space-y-4">

      <% if @inspection.completed? %>

        <%# 検出された異常 %>
        <div class="card p-4">
          <p style="font-size:0.65rem; font-weight:600; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.75rem;">
            検出された異常 &nbsp;<span style="color:var(--white); font-family:'DM Mono',monospace;"><%= @inspection.anomaly_count %>件</span>
          </p>

          <% if @inspection.anomalies.any? %>
            <div class="space-y-3">
              <% @inspection.anomalies.each do |anomaly| %>
                <% critical = anomaly['severity'] == 'critical' %>
                <div style="border-radius:0.5rem; padding:1rem; background:<%= critical ? 'rgba(226,75,74,0.08)' : 'rgba(239,159,39,0.08)' %>; border:1px solid <%= critical ? 'rgba(226,75,74,0.25)' : 'rgba(239,159,39,0.25)' %>;">
                  <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.5rem;">
                    <span class="badge <%= critical ? 'badge-error' : 'badge-warning' %>"><%= critical ? '重大' : '注意' %></span>
                    <span style="font-weight:500; font-size:0.875rem; color:var(--white); flex:1;"><%= anomaly['type'] %></span>
                    <span style="font-size:0.7rem; color:var(--gray-400);">📍 <%= anomaly['location'] %></span>
                  </div>
                  <p style="font-size:0.8rem; color:var(--gray-200); line-height:1.7; margin:0;"><%= anomaly['description'] %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div style="display:flex; align-items:center; gap:0.75rem; padding:1rem; background:rgba(29,158,117,0.08); border-radius:0.5rem; border:1px solid rgba(29,158,117,0.2);">
              <span style="font-size:1.2rem;">✓</span>
              <span style="color:#5DCAA5; font-size:0.875rem; font-weight:500;">異常は検出されませんでした</span>
            </div>
          <% end %>
        </div>

        <%# 推奨アクション %>
        <% recommendation = @display_recommendation %>
        <% if recommendation.present? %>
          <div class="card p-4" style="border-color:rgba(29,158,117,0.2); background:rgba(29,158,117,0.04);">
            <p style="font-size:0.65rem; font-weight:600; color:#5DCAA5; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.75rem;">推奨アクション</p>
            <div style="font-size:0.875rem; color:var(--gray-200); line-height:1.8;">
              <%= simple_format recommendation, {}, wrapper_tag: "div" %>
            </div>
          </div>
        <% end %>

      <% elsif @inspection.analyzing? %>
        <div class="card p-8 text-center">
          <div style="font-size:2.5rem; margin-bottom:1rem;">🤖</div>
          <p style="font-weight:500; color:var(--white); margin-bottom:0.5rem;">AI解析中...</p>
          <p style="font-size:0.875rem; color:var(--gray-400);">しばらくお待ちください</p>
        </div>

      <% elsif @inspection.failed? %>
        <div class="card p-6" style="border-color:rgba(226,75,74,0.3); background:rgba(226,75,74,0.06);">
          <p style="font-weight:600; color:var(--red); margin-bottom:0.5rem;">解析に失敗しました</p>
          <p style="font-size:0.875rem; color:#ff7a79;"><%= @inspection.result %></p>
        </div>

      <% else %>
        <div class="card p-8 text-center">
          <p style="color:var(--gray-400);">解析待機中...</p>
        </div>
      <% end %>

    </div>
  </div>
</div>
